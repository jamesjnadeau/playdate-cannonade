{
  "permissions": {
    "allow": [
      "Bash(lua5.4 *)",
      "Bash(which *)",
      "Bash(bash tests/run.sh)",
      "Bash(bash tools/simulate.sh)",
      "Bash(MERMAID_START_SCENE=* bash tools/simulate.sh)",
      "Bash(grep *)",
      "WebSearch",
      "WebFetch(domain:github.com)",
      "WebFetch(domain:raw.githubusercontent.com)",
      "WebFetch(domain:api.github.com)",
      "WebFetch(domain:sdk.play.date)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/scope-git-grep.sh\""
          }
        ]
      }
    ]
  }
}
